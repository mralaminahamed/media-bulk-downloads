{
  "name": "@mbd/extension",
  "version": "1.2.0",
  "private": true,
  "type": "module",
  "description": "The WXT browser-extension app — builds Chrome/Edge/Opera/Firefox (and, in future, Safari) from one codebase. Consumes @mbd/core, @mbd/storage, @mbd/platform.",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "build:edge": "wxt build -b edge",
    "build:safari": "wxt build -b safari",
    "build:all": "wxt build && wxt build -b firefox && wxt build -b edge",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "zip:edge": "wxt zip -b edge",
    "zip:safari": "wxt zip -b safari",
    "zip:all": "wxt zip && wxt zip -b firefox && wxt zip -b edge",
    "postinstall": "wxt prepare",
    "lint:firefox": "web-ext lint --source-dir .output/firefox-mv3",
    "type-check": "wxt prepare && tsc --noEmit",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "wxt build && playwright test",
    "test:e2e:headed": "wxt build && playwright test --headed"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@mbd/core": "workspace:*",
    "@mbd/platform": "workspace:*",
    "@mbd/storage": "workspace:*",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/postcss": "^4.3.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/chrome": "^0.2.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.10",
    "@wxt-dev/module-react": "^1.2.2",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.3.2",
    "vitest": "^4.1.10",
    "web-ext": "^10.5.0",
    "wxt": "^0.20.27"
  }
}
