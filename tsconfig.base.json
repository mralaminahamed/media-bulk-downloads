{
  // Shared compiler options for the workspace packages (@mbd/core, @mbd/storage,
  // @mbd/platform). Each package tsconfig extends this and adds `rootDir`, its
  // own `references`, and package-specific `types`. Mirrors the target/module/
  // resolution WXT uses for the app (.wxt/tsconfig.json) so type-checking is
  // consistent across the app and the packages.
  //
  // Packages are `composite` so the root can type-check the whole graph with
  // `tsc -b` in dependency order; they emit declaration files only (never
  // bundled — WXT/Vite consume the .ts source directly via package `exports`),
  // into a gitignored `.tsbuild/` per package.
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "useDefineForClassFields": true,
    "jsx": "react-jsx",
    "forceConsistentCasingInFileNames": true,
    "composite": true,
    "declaration": true,
    "emitDeclarationOnly": true,
    "declarationMap": false,
    "declarationDir": ".tsbuild"
  }
}
