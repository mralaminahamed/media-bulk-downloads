{
  "name": "@mralaminahamed/media-bulk-downloads",
  "private": true,
  "version": "1.2.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "description": "Cross-browser (Chrome, Firefox, Edge) Manifest V3 extension to bulk-download media from any web page — images (srcset, <picture>, CSS backgrounds), video, and audio — at original quality via per-site resolvers (X/Twitter, Instagram, Facebook, Threads, Bluesky, Mastodon, Pinterest, Reddit, Flickr, Vimeo, Dailymotion, and 50+ more) plus HLS/DASH stream capture. Smart type filters, instant preview, and a resilient download queue. Network-free by default.",
  "type": "module",
  "license": "MIT",
  "author": "Al Amin Ahamed <alamin.ahamed.dev@gmail.com>",
  "homepage": "https://github.com/mralaminahamed/media-bulk-downloads#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mralaminahamed/media-bulk-downloads.git"
  },
  "bugs": {
    "url": "https://github.com/mralaminahamed/media-bulk-downloads/issues"
  },
  "keywords": [
    "chrome-extension",
    "firefox-extension",
    "edge-extension",
    "browser-extension",
    "manifest-v3",
    "media-downloader",
    "image-downloader",
    "video-downloader",
    "audio-downloader",
    "bulk-download",
    "react",
    "wxt"
  ],
  "scripts": {
    "dev": "yarn workspace @mbd/extension dev",
    "dev:firefox": "yarn workspace @mbd/extension dev:firefox",
    "build": "yarn workspace @mbd/extension build",
    "build:firefox": "yarn workspace @mbd/extension build:firefox",
    "build:edge": "yarn workspace @mbd/extension build:edge",
    "build:safari": "yarn workspace @mbd/extension build:safari",
    "build:all": "yarn workspace @mbd/extension build:all",
    "zip": "yarn workspace @mbd/extension zip",
    "zip:firefox": "yarn workspace @mbd/extension zip:firefox",
    "zip:edge": "yarn workspace @mbd/extension zip:edge",
    "zip:safari": "yarn workspace @mbd/extension zip:safari",
    "zip:all": "yarn workspace @mbd/extension zip:all",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:firefox": "yarn workspace @mbd/extension lint:firefox",
    "type-check": "tsc -b packages/core packages/storage packages/platform && tsc --noEmit -p tsconfig.test.json && yarn workspace @mbd/extension type-check",
    "test": "vitest run --coverage && yarn workspace @mbd/extension test",
    "test:watch": "vitest",
    "test:e2e": "yarn workspace @mbd/extension test:e2e",
    "test:e2e:headed": "yarn workspace @mbd/extension test:e2e:headed"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.1",
    "@typescript-eslint/eslint-plugin": "^8.63.0",
    "@typescript-eslint/parser": "^8.63.0",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.6.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "resolutions": {
    "@types/node": "^26.1.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.4",
    "web-ext": "^10.5.0"
  },
  "engines": {
    "node": ">=20.19"
  },
  "packageManager": "yarn@4.17.1"
}
