{
  "name": "@mralaminahamed/media-bulk-downloads",
  "private": true,
  "version": "1.0.0",
  "description": "Chrome (Manifest V3) extension to collect and bulk-download media from any web page — images (including srcset, <picture>, and CSS backgrounds) plus direct-file video and audio.",
  "type": "module",
  "license": "MIT",
  "author": "Al Amin Ahamed <mrabir.ahamed@gmail.com>",
  "homepage": "https://github.com/mralaminahamed/media-bulk-downloads#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mralaminahamed/media-bulk-downloads.git"
  },
  "bugs": {
    "url": "https://github.com/mralaminahamed/media-bulk-downloads/issues"
  },
  "keywords": [
    "chrome-extension",
    "browser-extension",
    "manifest-v3",
    "media-downloader",
    "image-downloader",
    "video-downloader",
    "audio-downloader",
    "bulk-download",
    "react",
    "vite"
  ],
  "engines": {
    "node": ">=20.19"
  },
  "packageManager": "yarn@4.17.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "type-check": "tsc --noEmit",
    "test": "jest --coverage",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.7.1",
    "@eslint/js": "^10.0.1",
    "@heroicons/react": "^2.2.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/postcss": "^4.3.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/chrome": "^0.2.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.6.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.3.2",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3",
    "vite": "^8.1.3"
  }
}
