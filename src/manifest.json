{
  "manifest_version": 3,
  "name": "Image Bulk Downloads",
  "version": "1.0.0",
  "description": "Collect and download all images from a webpage",
  "permissions": [
    "activeTab",
    "downloads",
    "storage",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "src/extension/background.ts",
    "type": "module"
  },
  "action": {
    "default_popup": "public/index.html"
  },
  "options_page": "public/index.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/extension/content.ts"]
    }
  ],
  "icons": {
    "16": "public/assets/icon16.png",
    "32": "public/assets/icon32.png",
    "48": "public/assets/icon48.png",
    "128": "public/assets/icon128.png"
  }
}
